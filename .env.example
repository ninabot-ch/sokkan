# ── SOKKAN self-hosted ────────────────────────────────────────────────
# Copy to .env, fill in, then: docker compose up -d --build

# BYOK — pick ONE of the two:
# (a) Anthropic API key (sessions run on YOUR key)
ANTHROPIC_API_KEY=
# (b) Claude Pro/Max subscription: run `claude setup-token` on your desktop
#     (one-time browser login) and paste the token here
CLAUDE_CODE_OAUTH_TOKEN=

# Path to the project the sessions work on (mounted at /workspace)
SOKKAN_WORKSPACE=./workspace

# Access token asked on the login screen. Generate one:
#   openssl rand -hex 24
# Leave empty ONLY on a trusted network (open single-user access).
SOKKAN_LOCAL_TOKEN=

# Identity shown in the UI / audit journal
SOKKAN_OWNER_EMAIL=you@example.com
SOKKAN_OWNER_NAME=You

# Daily update check: one GET per day to sokkan.ch/dist/VERSION, so the UI can
# tell you when a new release is out. The request itself (your IP + a
# user-agent carrying the local version) is the ONLY thing transmitted —
# no telemetry, no identifiers. Set to 0 to disable entirely.
SOKKAN_UPDATE_CHECK=1
# Local version — written automatically by install.sh ("dev" on git checkouts)
#SOKKAN_VERSION=

# Role given to an authenticated email that is NOT in the users table.
# viewer (default) = read-only access ; none = reject with 403 (recommended
# when an IdP in front may authenticate more people than you want in SOKKAN).
#SOKKAN_DEFAULT_ROLE=viewer

# Web UI port on the host
SOKKAN_PORT=3009
SOKKAN_PUBLIC_URL=http://localhost:3009

SOKKAN_TZ=Europe/Zurich

# Optional: remote embedding service (POST {url}/api/v1/embed/text).
# Empty = local ONNX inference (multilingual MiniLM via fastembed).
ML_SERVICE_URL=

# Preview screenshots (SOKKAN_FEATURE_PREVIEW=1 instances only): by default the
# target URL must resolve to a PUBLIC address (SSRF guard — private, loopback,
# link-local and cloud-metadata IPs are refused). Set to 1 to allow private
# targets, e.g. to screenshot a dev-server on your LAN.
#SOKKAN_PREVIEW_ALLOW_PRIVATE=0

# Nina — embedded assistant (managed-cloud feature; opt-in on self-host).
# Enable with SOKKAN_FEATURE_ASSISTANT=1 — she then uses your configured LLM
# (BYOK key or included gateway). Dedicated endpoint override (optional):
# SOKKAN_FEATURE_ASSISTANT=0
# SOKKAN_ASSISTANT_LLM_URL=
# SOKKAN_ASSISTANT_LLM_TOKEN=
# SOKKAN_ASSISTANT_LLM_MODEL=qwen3-coder-plus
